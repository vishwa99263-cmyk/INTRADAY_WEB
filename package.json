{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "sync:upload": "git add . && git commit -m \"Auto Sync Update\" && git push -u origin main",
    "sync:download": "git pull origin main",
    "pm2:stop": "npx pm2 stop all && npx pm2 delete all && npx pm2 save --force"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fyers-api-v3": "^1.8.0",
    "fyers-web-sdk-v3": "^1.7.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "technicalindicators": "^3.1.0",
    "vite": "^6.2.3",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
